APP_NAME="Imbuo Library"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=imbuo_library
DB_USERNAME=imbuo
DB_PASSWORD=secret

# Headless service: no sessions, no queue workers. Cache MUST be a shared,
# persistent store (database) — the pipeline overlap guards are cache locks.
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Read API consumers — comma-separated name:token pairs, e.g.
# LIBRARY_READ_TOKENS=mnsa:abc...,sponge:def...,admin:ghi...
LIBRARY_READ_TOKENS=

STREAMING_AVAILABILITY_API_KEY=
STREAMING_AVAILABILITY_BASE_URL=https://api.movieofthenight.com/v4
STREAMING_AVAILABILITY_QPS=5
TMDB_API_KEY=

# Book library seeds/enrichment (book:weekly, book:seed, book:enrich)
NYT_BOOKS_API_KEY=
GOOGLE_BOOKS_API_KEY=

# Netflix Kids verification (streaming:verify-kids) — US egress + Kids profile cookie
NETFLIX_KIDS_COOKIE=
NETFLIX_KIDS_PERSISTED_QUERY_ID=8d902979-56f2-4886-8c16-f8910f6b52ee
NETFLIX_KIDS_PERSISTED_QUERY_VERSION=102
